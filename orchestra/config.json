{
  "mode": "persistent",
  "broker_port": 7899,
  "tmux_session": "orchestra",
  "budget_cap_usd": 5.00,
  "require_approval_for_deploy": true,
  "require_approval_for_commit": false,
  "architecture": "manager-ceo",
  "models": {
    "manager": "sonnet",
    "ceo": "opus",
    "frontend": "sonnet",
    "backend": "sonnet",
    "devops": "haiku",
    "content": "sonnet",
    "mcp": "sonnet"
  },
  "escalation": {
    "always": [
      "task touches auth or payment files",
      "multi-department coordination (2+ departments)",
      "revenue or positioning decisions",
      "architecture changes (new tables, routes, MCP tools)",
      "user explicitly requests CEO review",
      "manager has attempted a fix twice and it's still failing"
    ],
    "never": [
      "file reads, searches, grep, status checks",
      "single-file edits with clear scope",
      "smoke tests, deploys (with user approval)",
      "git operations (commits, diffs, logs)",
      "answering factual questions from RAG or memory",
      "spawning routine subagents"
    ],
    "brief_max_tokens": 500
  },
  "rag": {
    "enabled": false,
    "server": "tools/rag_server.py",
    "seed": "tools/rag_seed.py",
    "working_dir": ".rag",
    "embedding_model": "BAAI/bge-small-en-v1.5",
    "use_ollama": false
  },
  "departments": {
    "frontend": {
      "name": "Frontend",
      "emoji": "⚡",
      "allowed_paths": ["src/", "templates/", "static/"],
      "description": "UI, templates, CSS, UX, client-side code"
    },
    "backend": {
      "name": "Backend",
      "emoji": "🔧",
      "allowed_paths": ["src/", "scripts/", "migrations/"],
      "description": "Database, auth, API logic, data processing"
    },
    "devops": {
      "name": "DevOps",
      "emoji": "🚀",
      "allowed_paths": ["Dockerfile", "docker-compose.yml", "*.toml", ".github/"],
      "description": "Deployment, health checks, CI/CD, infrastructure"
    },
    "content": {
      "name": "Content/SEO",
      "emoji": "📝",
      "allowed_paths": ["src/", "docs/", "README.md"],
      "description": "Copy, meta tags, documentation, SEO"
    },
    "mcp": {
      "name": "Integration",
      "emoji": "🔌",
      "allowed_paths": ["src/", "pyproject.toml", "package.json"],
      "description": "External APIs, integrations, publishing"
    }
  },
  "ceo": {
    "name": "CEO / Strategy & QA",
    "emoji": "🎯",
    "allowed_paths": ["*"],
    "description": "Strategic gate. Reviews multi-department plans, revenue decisions, architecture changes. Departments can escalate directly for complex technical issues. Persistent in tmux.",
    "review_criteria": [
      "evidence of demand (not just good idea)",
      "revenue path within 30 days",
      "opportunity cost vs current priorities",
      "overconfidence signals",
      "strategic coherence with existing work"
    ],
    "verdict_format": "approve | challenge | veto"
  }
}
